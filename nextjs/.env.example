# API Configuration
NEXT_PUBLIC_API_BASE_URL=http://localhost:5000/api

# Site URL (for metadata, sitemap, robots, and canonical URLs)
NEXT_PUBLIC_SITE_URL=https://luggagecoverbd.com

# Google Analytics (optional — leave as placeholder to disable)
NEXT_PUBLIC_GA_ID=YOUR_GA_ID

# Google Site Verification (optional)
# GOOGLE_VERIFICATION=your_verification_code

# Optional: MongoDB (for future full-stack migration)
# MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/luggagecoverbd
